# =========================
# 基础配置
# =========================
PROJECT_NAME=FastAPI Starter
VERSION=0.1.0

# =========================
# 数据库 / 缓存
# 本地直接运行时可使用 localhost
# Docker Compose 环境会自动覆盖为容器内地址
# =========================
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fastapi_db
REDIS_URL=redis://localhost:6379/0

# =========================
# JWT 鉴权
# 请替换为你自己的随机字符串
# =========================
SECRET_KEY=replace_with_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =========================
# LLM / Embedding 配置
# 默认使用本地 Ollama 的 OpenAI 兼容接口
# =========================
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:3b
EMBEDDING_MODEL_NAME=bge-m3
LLM_PROVIDER=ollama

# 若后续切换到云模型，可填写估算单价，便于成本统计
LLM_INPUT_PRICE_PER_1K_TOKENS=0
LLM_OUTPUT_PRICE_PER_1K_TOKENS=0
